RewriteEngine On

# If the request is for an existing file (CSS, JS, images), serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Block direct access to app/ directory
RewriteRule ^app/ - [F,L]

# Route everything else through the front controller
RewriteRule ^(.*)$ index.php [QSA,L]
